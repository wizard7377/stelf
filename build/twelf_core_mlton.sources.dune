 (target compSyn.sml.ml)
 (action
  (write-file compSyn.sml.ml "")))

(rule
 (target compSyn.ml)
 (deps
  (:sig compSyn.sig.ml)
  (:fun compSyn.fun.ml)
  (:sml compSyn.sml.ml))
 (action
  (progn
   (concurrent
    (copy# %{sig} %{sig}s)
    (copy# %{fun} %{fun}s)
    (copy# %{sml} %{sml}s))
   (with-stdout-to
    %{target}
    (progn
     (cat %{sig}s)
     (echo "\n")
     (cat %{fun}s)
     (echo "\n")
     (cat %{sml}s))))))
      
