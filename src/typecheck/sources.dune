(rule
 (mode fallback)
 (target strict.sml.ml)
 (action
  (write-file strict.sml.ml "")))

(rule
 (target strict.ml)
 (deps
  (:sig strict.sig.ml)
  (:fun strict.fun.ml)
  (:sml strict.sml.ml))
 (action
  (progn
   (concurrent
    (copy# %{sig} %{sig}s)
    (copy# %{fun} %{fun}s)
    (copy# %{sml} %{sml}s))
   (with-stdout-to
    %{target}
    (progn
     (cat %{sig}s)
     (echo "\n")
     (cat %{fun}s)
     (echo "\n")
     (cat %{sml}s))))))
      