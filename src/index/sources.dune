 (target index_.sml.ml)
 (action
  (write-file index_.sml.ml "")))

(rule
 (target index_.ml)
 (deps
  (:sig index_.sig.ml)
  (:fun index_.fun.ml)
  (:sml index_.sml.ml))
 (action
  (progn
   (concurrent
    (copy# %{sig} %{sig}s)
    (copy# %{fun} %{fun}s)
    (copy# %{sml} %{sml}s))
   (with-stdout-to
    %{target}
    (progn
     (cat %{sig}s)
     (echo "\n")
     (cat %{fun}s)
     (echo "\n")
     (cat %{sml}s))))))
      