 (target timing_.sml.ml)
 (action
  (write-file timing_.sml.ml "")))

(rule
 (target timing_.ml)
 (deps
  (:sig timing_.sig.ml)
  (:fun timing_.fun.ml)
  (:sml timing_.sml.ml))
 (action
  (progn
   (concurrent
    (copy# %{sig} %{sig}s)
    (copy# %{fun} %{fun}s)
    (copy# %{sml} %{sml}s))
   (with-stdout-to
    %{target}
    (progn
     (cat %{sig}s)
     (echo "\n")
     (cat %{fun}s)
     (echo "\n")
     (cat %{sml}s))))))
      