
      (rule
 (mode fallback)
 (target timers.sig.ml)
 (action
  (write-file timers.sig.ml "")))

(rule
 (mode fallback)
 (target timers.fun.ml)
 (action
  (write-file timers.fun.ml "")))

(rule
 (mode fallback)
 (target timers.sml.ml)
 (action
  (write-file timers.sml.ml "")))

(rule
 (target timers.ml)
 (deps
  (:sig timers.sig.ml)
  (:fun timers.fun.ml)
  (:sml timers.sml.ml))
 (action
  (progn
   (concurrent
    (copy# %{sig} %{sig}s)
    (copy# %{fun} %{fun}s)
    (copy# %{sml} %{sml}s))
   (with-stdout-to
    %{target}
    (progn
     (cat %{sig}s)
     (echo "\n")
     (cat %{fun}s)
     (echo "\n")
     (cat %{sml}s))))))
      
